            { "value": "h0", "label": "Çok Büyük" },
            { "value": "h1", "label": "Büyük" },
            { "value": "h2", "label": "Orta" },
            { "value": "h3", "label": "Küçük" }
          ]
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "Hizalama",
          "default": "left",
          "options": [
            { "value": "left", "label": "Sol" },
            { "value": "center", "label": "Orta" }
          ]
        },
        {
          "type": "checkbox",
          "id": "uppercase",
          "default": false,
          "label": "Büyük harf"
        },
        {
          "type": "range",
          "id": "margin_top",
          "min": 0,
          "max": 30,
          "step": 2,
          "default": 0,
          "unit": "px",
          "label": "Üst boşluk"
        },
        {
          "type": "range",
          "id": "margin_bottom",
          "min": 0,
          "max": 30,
          "step": 2,
          "default": 4,
          "unit": "px",
          "label": "Alt boşluk"
        }
      ]
    },
    {
      "type": "price",
      "name": "Fiyat",
      "limit": 1,
      "settings": [
        {
          "type": "range",
          "id": "price_size",
          "min": 16,
          "max": 40,
          "step": 2,
          "default": 28,
          "unit": "px",
          "label": "Fiyat boyutu"
        },
        {
          "type": "range",
          "id": "price_weight",
          "min": 400,
          "max": 900,
          "step": 100,
          "default": 800,
          "label": "Fiyat kalınlığı"
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "Hizalama",
          "default": "left",
          "options": [
            { "value": "left", "label": "Sol" },
            { "value": "center", "label": "Orta" }
          ]
        },
        {
          "type": "checkbox",
