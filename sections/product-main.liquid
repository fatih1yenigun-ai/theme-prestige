{%- assign product = product -%}
{%- assign current_variant = product.selected_or_first_available_variant -%}

<section class="product-section">
  <div class="container">
    <div class="product-grid">
      <!-- Product Images -->
      <div class="product-images">
        <img
          class="product-main-image"
          src="{{ product.featured_image | image_url: width: 800 }}"
          alt="{{ product.featured_image.alt | escape }}"
          id="ProductMainImage"
          width="800"
          height="800"
          loading="eager"
        >
        <div class="product-thumbnails">
          {% for image in product.images %}
            <img
              class="product-thumbnail{% if forloop.first %} active{% endif %}"
              src="{{ image | image_url: width: 150 }}"
              alt="{{ image.alt | escape }}"
              width="72"
              height="72"
              loading="lazy"
              onclick="document.getElementById('ProductMainImage').src='{{ image | image_url: width: 800 }}'; document.querySelectorAll('.product-thumbnail').forEach(t=>t.classList.remove('active')); this.classList.add('active');"
            >
          {% endfor %}
        </div>
      </div>

      <!-- Product Info -->
      <div class="product-info">
        <h1 class="product-title">{{ product.title }}</h1>

        {% if section.settings.show_subtitle %}
          <p class="product-subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}

        {% if section.settings.show_rating %}
          <div class="product-rating">
            <div class="stars">
              {% for i in (1..5) %}
                {% if i <= section.settings.rating %}
                  ★
                {% else %}
                  ☆
                {% endif %}
              {% endfor %}
            </div>
            <span class="rating-count">({{ section.settings.review_count }} değerlendirme)</span>
          </div>
        {% endif %}

        <div class="product-price">
          <span id="ProductPrice">{{ current_variant.price | money }}</span>
          {% if current_variant.compare_at_price > current_variant.price %}
            <span class="compare-price">{{ current_variant.compare_at_price | money }}</span>
          {% endif %}
        </div>

        <!-- Variant Selector -->
        {% if product.has_only_default_variant == false %}
          <div class="variant-selector" id="VariantSelector">
            {% for variant in product.variants %}
              <label class="variant-option{% if variant == current_variant %} selected{% endif %}" data-variant-id="{{ variant.id }}">
                <div>
                  <span class="variant-label">{{ variant.title }}</span>
                  {% if variant.compare_at_price > variant.price %}
                    <br><span class="variant-save">{{ variant.compare_at_price | minus: variant.price | money }} tasarruf</span>
                  {% endif %}
                </div>
                <span class="variant-price">{{ variant.price | money }}</span>
              </label>
            {% endfor %}
          </div>
        {% endif %}

        <form method="post" action="/cart/add">
          <input type="hidden" name="id" value="{{ current_variant.id }}" id="VariantId">
          <button type="submit" class="btn btn-primary add-to-cart">
            {{ section.settings.add_to_cart_text }}
          </button>
        </form>

        {% if section.settings.show_buy_now %}
          <button class="buy-now" onclick="window.location.href='/checkout'">
            {{ section.settings.buy_now_text }}
          </button>
        {% endif %}

        {% if section.settings.show_trust_badges %}
          <div class="trust-badges">
            {% for block in section.blocks %}
              {% if block.type == 'trust_badge' %}
                <div class="trust-badge">
                  <span class="trust-badge-icon">{{ block.settings.icon }}</span>
                  <span>{{ block.settings.label }}</span>
                </div>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.variant-option').forEach(function(el) {
    el.addEventListener('click', function() {
      document.querySelectorAll('.variant-option').forEach(function(o) { o.classList.remove('selected'); });
      this.classList.add('selected');
      document.getElementById('VariantId').value = this.dataset.variantId;
    });
  });
</script>

{% schema %}
{
  "name": "Ürün Detay",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_subtitle",
      "label": "Alt Başlık Göster",
      "default": true
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Alt Başlık",
      "default": "Doğal deniz tuzu ile saçlarınıza hacim ve doku kazandırın. Plaj dalgası efekti için ideal."
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Puan Göster",
      "default": true
    },
    {
      "type": "range",
      "id": "rating",
      "label": "Yıldız Puanı",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Değerlendirme Sayısı",
      "default": "2,847"
    },
    {
      "type": "text",
      "id": "add_to_cart_text",
      "label": "Sepete Ekle Butonu",
      "default": "SEPETE EKLE"
    },
    {
      "type": "checkbox",
      "id": "show_buy_now",
      "label": "Hemen Al Butonu Göster",
      "default": true
    },
    {
      "type": "text",
      "id": "buy_now_text",
      "label": "Hemen Al Butonu Metni",
      "default": "HEMEN SATIN AL"
    },
    {
      "type": "checkbox",
      "id": "show_trust_badges",
      "label": "Güven Rozetleri Göster",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Güven Rozeti",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "İkon (Emoji)",
          "default": "🚚"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Etiket",
          "default": "Ücretsiz Kargo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ürün Detay"
    }
  ]
}
{% endschema %}
