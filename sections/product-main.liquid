          "label": "İkon boyutu"
        },
        {
          "type": "range",
          "id": "text_size",
          "min": 11,
          "max": 20,
          "step": 1,
          "default": 14,
          "unit": "px",
          "label": "Yazı boyutu"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Metin rengi",
          "default": "#999999"
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "Hizalama",
          "default": "left",
          "options": [
            { "value": "left", "label": "Sol" },
            { "value": "center", "label": "Orta" }
          ]
        },
        {
          "type": "range",
          "id": "margin_top",
          "min": 0,
          "max": 30,
          "step": 2,
          "default": 0,
