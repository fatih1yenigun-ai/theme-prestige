<section class="faq-section" style="background: {{ section.settings.bg_color }};">
  <div class="container">
    <h2 class="section-heading">{{ section.settings.heading }}</h2>
    <div class="faq-list">
      {% for block in section.blocks %}
        <div class="faq-item" {{ block.shopify_attributes }}>
          <button class="faq-question" aria-expanded="false">
            <span>{{ block.settings.question }}</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">{{ block.settings.answer }}</div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Sıkça Sorulan Sorular",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Başlık",
      "default": "Sıkça Sorulan Sorular"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Arka Plan Rengi",
      "default": "#0a0a0a"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "Soru",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Soru",
          "default": "Deniz tuzu spreyi nasıl kullanılır?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Cevap",
          "default": "<p>Nemli veya kuru saçlara 2-3 sıkım uygulayın. Parmaklarınızla şekil verin ve kurumasını bekleyin. Doğal, hacimli bir görünüm elde edin.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Sıkça Sorulan Sorular",
      "blocks": [
        { "type": "faq", "settings": { "question": "Deniz tuzu spreyi nasıl kullanılır?", "answer": "<p>Nemli veya kuru saçlara 2-3 sıkım uygulayın. Parmaklarınızla şekil verin ve kurumasını bekleyin.</p>" } },
        { "type": "faq", "settings": { "question": "Hangi saç tiplerine uygun?", "answer": "<p>Tüm saç tiplerine uygundur. Özellikle düz ve ince saçlarda harika hacim ve doku sağlar.</p>" } },
        { "type": "faq", "settings": { "question": "Saçıma zarar verir mi?", "answer": "<p>Hayır. Doğal içerikleri sayesinde saçınıza zarar vermez, aksine besleyici yardımcı olur.</p>" } },
        { "type": "faq", "settings": { "question": "Ne kadar süre dayanır?", "answer": "<p>Günlük kullanımda yaklaşık 2-3 ay dayanır. 200ml büyük boy şişe.</p>" } },
        { "type": "faq", "settings": { "question": "İade politikanız nedir?", "answer": "<p>30 gün içinde koşulsuz iade garantisi sunuyoruz. Memnun kalmazsanız paranızı iade ediyoruz.</p>" } }
      ]
    }
  ]
}
{% endschema %}
